# Photo Background changer

from PIL import Image

def change_background(image_path, background_path, output_path):
    # Open the image and the background
    image = Image.open(image_path)
    background = Image.open(background_path)

    # Resize the background to match the size of the image
    background = background.resize(image.size, Image.ANTIALIAS)

    # Blend the image and the background using alpha blending
    blended_image = Image.alpha_composite(background.convert('RGBA'), image.convert('RGBA'))

    # Save the blended image with the new background
    blended_image.save(output_path)

    print("Background changed successfully!")


# Example usage
image_path = "path_to_your_image.jpg"
background_path = "path_to_your_background_image.jpg"
output_path = "output_image.jpg"

change_background(image_path, background_path, output_path)
